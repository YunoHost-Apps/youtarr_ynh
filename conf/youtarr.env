# Youtarr Configuration
# This file is automatically generated by YunoHost

# Internal port the Node server listens on (nginx proxies to this)
PORT=__PORT__

# Database connection (shared MariaDB instance)
DB_HOST=localhost
DB_PORT=3306
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PWD__
DB_NAME=__DB_NAME__

# Where downloaded videos are stored
DATA_PATH=__DATA_DIR__
YOUTUBE_OUTPUT_DIR=__DATA_DIR__

# Authentication (Youtarr has its own login system)
AUTH_ENABLED=true
AUTH_PRESET_USERNAME=__ADMIN__
AUTH_PRESET_PASSWORD=__PASSWORD__

# Reverse proxy (nginx) sits in front of the app
TRUST_PROXY=1

LOG_LEVEL=info
TZ=UTC
