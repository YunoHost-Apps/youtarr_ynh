#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

# config/config.json, jobs/ and server/images/ hold Youtarr's runtime state
# (Plex settings, download history, thumbnails...) and .env holds secrets
# generated at install time: none of that should be wiped on upgrade.
ynh_setup_source --dest_dir="$install_dir" --full_replace --keep="config jobs server/images .env"

mkdir -p "$install_dir/config" "$install_dir/jobs" "$install_dir/server/images" "$install_dir/bin"

#=================================================
# UPDATE YT-DLP
#=================================================
ynh_script_progression "Updating yt-dlp..."

ynh_setup_source --source_id="yt-dlp" --dest_dir="$install_dir/bin"
chmod +x "$install_dir/bin/yt-dlp"

#=================================================
# UPDATE DENO (JS RUNTIME FOR YT-DLP)
#=================================================
ynh_script_progression "Updating Deno..."

ynh_setup_source --source_id="deno" --dest_dir="$install_dir/bin"
chmod +x "$install_dir/bin/deno"

#=================================================
# UPDATE APPRISE
#=================================================
ynh_script_progression "Updating Apprise..."

python3 -m venv "$install_dir/venv"
ynh_hide_warnings "$install_dir/venv/bin/pip" install --quiet --upgrade pip
ynh_hide_warnings "$install_dir/venv/bin/pip" install --quiet --upgrade apprise

cat > "$install_dir/bin/apprise" <<EOF
#!/bin/sh
exec "$install_dir/venv/bin/python3" -c "from apprise.cli import main; main()" "\$@"
EOF
chmod +x "$install_dir/bin/apprise"

#=================================================
# BUILD APP
#=================================================
ynh_script_progression "Building Youtarr... This may take a while"

pushd "$install_dir"
    ynh_hide_warnings ynh_exec_as_app npm ci --omit=dev --ignore-scripts
popd

pushd "$install_dir/client"
    ynh_hide_warnings ynh_exec_as_app npm ci --ignore-scripts
    ynh_hide_warnings ynh_exec_as_app npm run build
    ynh_safe_rm node_modules
popd

#=================================================
# REAPPLY SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

ynh_config_add_nginx

ynh_config_add_systemd
yunohost service add "$app" --description="Automated YouTube channel/playlist downloader" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

chown -R "$app:$app" "$install_dir"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start" --log_path="/var/log/$app/$app.log" --wait_until="Server started and listening"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
