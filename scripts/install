#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Setting up source files..."

ynh_setup_source --dest_dir="$install_dir" --keep="config jobs server/images .env"

mkdir -p "$install_dir/config" "$install_dir/jobs" "$install_dir/server/images" "$install_dir/bin"

#=================================================
# INSTALL YT-DLP
#=================================================
ynh_script_progression "Installing yt-dlp..."

ynh_setup_source --source_id="yt-dlp" --dest_dir="$install_dir/bin"
chmod +x "$install_dir/bin/yt-dlp"

#=================================================
# INSTALL APPRISE (NOTIFICATIONS)
#=================================================
ynh_script_progression "Installing Apprise..."

python3 -m venv "$install_dir/venv"
ynh_exec_warn_less "$install_dir/venv/bin/pip" install --quiet --upgrade pip
ynh_exec_warn_less "$install_dir/venv/bin/pip" install --quiet apprise

cat > "$install_dir/bin/apprise" <<EOF
#!/bin/sh
exec "$install_dir/venv/bin/python3" -c "from apprise.cli import main; main()" "\$@"
EOF
chmod +x "$install_dir/bin/apprise"

#=================================================
# BUILD APP
#=================================================
ynh_script_progression "Building Youtarr... This may take a while"

pushd "$install_dir"
    ynh_hide_warnings ynh_exec_as_app npm ci --omit=dev
popd

pushd "$install_dir/client"
    ynh_hide_warnings ynh_exec_as_app npm ci
    ynh_hide_warnings ynh_exec_as_app npm run build
    ynh_safe_rm node_modules
popd

#=================================================
# APP INITIAL CONFIGURATION
#=================================================
ynh_script_progression "Adding $app's configuration files..."

ynh_config_add --template="youtarr.env" --destination="$install_dir/.env"
chmod 600 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations related to $app..."

# Create a dedicated NGINX config
ynh_config_add_nginx

# Create a dedicated systemd config
ynh_config_add_systemd
yunohost service add "$app" --description="Automated YouTube channel/playlist downloader" --log="/var/log/$app/$app.log"

# Use logrotate to manage application logfile(s)
ynh_config_add_logrotate

mkdir -p "/var/log/$app"
touch "/var/log/$app/$app.log"
chown -R "$app:$app" "/var/log/$app"

chown -R "$app:$app" "$install_dir"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start" --log_path="/var/log/$app/$app.log" --line_match="Server started and listening"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
